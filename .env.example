# =============================================================================
# KG-ProWeight environment variables. Copy to `.env` and source before running.
# =============================================================================

# --- Project layout (override only if you keep data outside the repo) --------
export KGPW_PROJECT_ROOT=$(pwd)
export KGPW_DATA_DIR=$KGPW_PROJECT_ROOT/data
export KGPW_INDEX_DIR=$KGPW_PROJECT_ROOT/indexes
export KGPW_CHECKPOINT_DIR=$KGPW_PROJECT_ROOT/checkpoints
export KGPW_OUTPUT_DIR=$KGPW_PROJECT_ROOT/outputs

# --- FlashRAG (external dependency) ------------------------------------------
# If FlashRAG is `pip install -e`'d, you can leave this empty.
export KGPW_FLASHRAG_ROOT=$KGPW_PROJECT_ROOT/third_party/FlashRAG

# --- Model paths (HF id or local checkout) -----------------------------------
export KGPW_LLAMA3_PATH=meta-llama/Meta-Llama-3-8B-Instruct
export KGPW_E5_PATH=intfloat/e5-base-v2
export KGPW_REARAG_PATH=THU-KEG/ReaRAG-9B
export KGPW_R1SEARCHER_PATH=XXsongLALA/Qwen-2.5-7B-base-RAG-RL
export KGPW_SELFRAG_PATH=selfrag/selfrag_llama2_7b

# --- API keys ----------------------------------------------------------------
# OpenAI is used for: Teacher (GPT-4o) and IHR LLM-as-Judge (GPT-4o).
export OPENAI_API_KEY=
export OPENAI_BASE_URL=https://api.openai.com/v1
# DeepSeek is recommended as a cheaper Teacher backend.
export DEEPSEEK_API_KEY=sk-your-deepseek-api-key
export DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- GPU / runtime -----------------------------------------------------------
export CUDA_VISIBLE_DEVICES=0
export PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
export HF_ENDPOINT=https://huggingface.co
# export HF_ENDPOINT=https://hf-mirror.com  # uncomment behind GFW
